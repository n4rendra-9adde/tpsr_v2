# TPSR API Environment Configuration Template
# Copy this file to .env and supply real values before starting the server.
# Do not commit .env to version control.

PORT=3000

# PostgreSQL connection settings
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_DB=tpsr
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_SSL=false

# Hyperledger Fabric connection settings
FABRIC_CONNECTION_PROFILE=
FABRIC_WALLET_PATH=
FABRIC_IDENTITY=
FABRIC_CHANNEL_NAME=
FABRIC_CHAINCODE_NAME=
