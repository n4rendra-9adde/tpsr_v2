# TPSR Deployment Environment Template
# Copy this file to deploy.env and fill in values before running deploy.sh.
# Do not commit deploy.env to version control.
# Adjust all values to match your deployment environment.

# Fabric channel and chaincode configuration
CHANNEL_NAME=
CHAINCODE_NAME=
CHAINCODE_VERSION=
CHAINCODE_SEQUENCE=

# API runtime settings
API_PORT=3000
API_ENV_FILE=../api/.env

# Dashboard runtime settings
DASHBOARD_ENV_FILE=../dashboard/.env

# Deployment control flags
START_API=true
START_DASHBOARD=true
RUN_POST_DEPLOY_TESTS=false
