# TPSR Dashboard Environment Configuration Template
# Copy this file to .env and supply real values before building or running the dashboard.
# Do not commit .env to version control.
#
# Note: Role variables below are temporary integration helpers used to pass
# request headers to the backend. They must be replaced with a real auth
# mechanism before production deployment.

REACT_APP_API_BASE_URL=http://localhost:3000/api
REACT_APP_USER_ID=
REACT_APP_SBOMS_ROLE=security
REACT_APP_VERIFY_ROLE=auditor
REACT_APP_HISTORY_ROLE=auditor
REACT_APP_COMPLIANCE_ROLE=admin
